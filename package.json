{
  "name": "gign",
  "version": "0.0.3",
  "description": "gign generate .gitignore for your project",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/juninmd/gign.git"
  },
  "author": "Antonio Carlos",
  "bugs": {
    "url": "https://github.com/juninmd/gign/issues"
  },
  "keywords": [
    "git",
    "gitignore"
  ],
  "homepage": "https://github.com/juninmd/gign#readme",
  "license": "MIT",
  "dependencies": {
    "loading-indicator": "^2.0.0",
    "node-fetch": "^3.3.2"
  },
  "preferGlobal": true,
  "bin": {
    "gign": "dist/index.js"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "esbuild": "^0.27.4",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.0",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "prettier": "^3.8.1"
  },
  "scripts": {
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "esbuild index.js --bundle --minify --sourcemap --platform=node --target=node20 --external:electron --outfile=dist/index.js",
    "prepack": "npm run build"
  }
}
